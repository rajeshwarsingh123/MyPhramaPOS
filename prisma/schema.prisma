generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Medicine {
  id            String     @id @default(cuid())
  name          String
  genericName   String?
  companyName   String?
  composition   String?
  strength      String?
  category      String?
  unitType      String     @default("tablet")
  packSize      String?
  gstPercent    Float      @default(5)
  sellingPrice  Float      @default(0)
  marginPercent Float      @default(0)
  tenantId      String
  batches       Batch[]
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  saleItems     SaleItem[]

  @@index([tenantId])
}

model Batch {
  id              String        @id @default(cuid())
  medicineId      String
  batchNumber     String
  expiryDate      DateTime
  mfgDate         DateTime?
  purchasePrice   Float
  mrp             Float
  quantity        Int           @default(0)
  initialQuantity Int           @default(0)
  isActive        Boolean       @default(true)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  tenantId        String
  medicine        Medicine      @relation(fields: [medicineId], references: [id], onDelete: Cascade)
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseItem    PurchaseItem?
  saleItems       SaleItem[]

  @@index([tenantId])
  @@index([medicineId])
  @@index([expiryDate])
  @@index([batchNumber])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  phone          String?
  email          String?
  address        String?
  gstNumber      String?
  tenantId       String
  purchaseOrders PurchaseOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model Customer {
  id         String  @id @default(cuid())
  name       String
  phone      String?
  email      String?
  address    String?
  doctorName String?
  tenantId   String
  tenant     Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  sales      Sale[]

  @@index([tenantId])
}

model PurchaseOrder {
  id          String         @id @default(cuid())
  supplierId  String
  invoiceNo   String?
  invoiceDate DateTime       @default(now())
  totalAmount Float          @default(0)
  totalGst    Float          @default(0)
  notes       String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  tenantId    String
  items       PurchaseItem[]
  supplier    Supplier       @relation(fields: [supplierId], references: [id])
  tenant      Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([supplierId])
  @@index([invoiceDate])
}

model PurchaseItem {
  id              String        @id @default(cuid())
  purchaseOrderId String
  batchId         String        @unique
  quantity        Int
  purchasePrice   Float
  mrp             Float
  gstPercent      Float         @default(5)
  totalAmount     Float         @default(0)
  batch           Batch         @relation(fields: [batchId], references: [id])
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
}

model Sale {
  id            String     @id @default(cuid())
  customerId    String?
  doctorName    String?
  invoiceNo     String     @unique
  saleDate      DateTime   @default(now())
  subtotal      Float      @default(0)
  totalGst      Float      @default(0)
  totalDiscount Float      @default(0)
  totalAmount   Float      @default(0)
  paymentMode   String     @default("cash")
  notes         String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  tenantId      String
  returns       Return[]
  customer      Customer?  @relation(fields: [customerId], references: [id])
  tenant        Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items         SaleItem[]

  @@index([tenantId])
  @@index([customerId])
  @@index([saleDate])
}

model SaleItem {
  id           String   @id @default(cuid())
  saleId       String
  batchId      String
  medicineId   String
  medicineName String
  quantity     Int
  mrp          Float
  discount     Float    @default(0)
  gstPercent   Float    @default(5)
  gstAmount    Float    @default(0)
  totalAmount  Float    @default(0)
  returns      Return[]
  batch        Batch    @relation(fields: [batchId], references: [id])
  medicine     Medicine @relation(fields: [medicineId], references: [id])
  sale         Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  @@index([saleId])
  @@index([batchId])
}

model Return {
  id           String   @id @default(cuid())
  saleId       String
  saleItemId   String
  returnQty    Int
  reason       String
  refundAmount Float
  returnDate   DateTime @default(now())
  tenantId     String
  sale         Sale     @relation(fields: [saleId], references: [id])
  saleItem     SaleItem @relation(fields: [saleItemId], references: [id])
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([saleId])
}

model StoreSetting {
  id               String   @id @default(cuid())
  storeName        String   @default("My Pharmacy")
  phone            String?
  email            String?
  address          String?
  gstNumber        String?
  licenseNo        String?
  logoUrl          String?
  invoicePrefix    String   @default("INV")
  nextInvoiceNo    Int      @default(1)
  dailySalesTarget Float    @default(10000)
  updatedAt        DateTime @updatedAt
  tenantId         String   @unique
  tenant           Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Admin {
  id        String    @id @default(cuid())
  name      String
  email     String    @unique
  password  String
  role      String    @default("staff")
  isActive  Boolean   @default(true)
  lastLogin DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Tenant {
  id              String          @id @default(cuid())
  name            String
  email           String          @unique
  phone           String?
  businessName    String
  businessPhone   String?
  businessAddress String?
  gstNumber       String?
  plan            String          @default("yearly")
  status          String          @default("active")
  passwordHash    String
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  batches         Batch[]
  customers       Customer[]
  medicines       Medicine[]
  purchaseOrders  PurchaseOrder[]
  returns         Return[]
  sales           Sale[]
  storeSetting    StoreSetting?
  subscriptions   Subscription[]
  subscriptionHistory SubscriptionHistory[]
  suppliers       Supplier[]
  supportTickets  SupportTicket[]
  systemLogs      SystemLog[]
}

model Subscription {
  id            String   @id @default(cuid())
  tenantId      String   @unique
  plan          String   @default("yearly")
  amount        Float    @default(0)
  status        String   @default("active") // active, expired, suspended
  startDate     DateTime @default(now())
  expiryDate    DateTime
  paymentStatus String   @default("paid") // paid, pending
  renewalCount  Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model SubscriptionHistory {
  id            String   @id @default(cuid())
  tenantId      String
  startDate     DateTime
  expiryDate    DateTime
  amount        Float
  paymentMode   String?
  transactionId String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

model SupportTicket {
  id          String   @id @default(cuid())
  tenantId    String
  subject     String
  description String
  status      String   @default("open")
  priority    String   @default("medium")
  replies     String   @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
}

model SystemLog {
  id        String   @id @default(cuid())
  tenantId  String?
  action    String
  details   String?
  createdAt DateTime @default(now())
  tenant    Tenant?  @relation(fields: [tenantId], references: [id])

  @@index([tenantId])
  @@index([createdAt])
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  message   String
  type      String   @default("info")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  otp       String
  userType  String
  userId    String?
  purpose   String   @default("password_reset")
  isUsed    Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([otp])
  @@index([expiresAt])
}
